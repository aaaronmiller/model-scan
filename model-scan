# FETCH OPENROUTER FREE MODELS FROM API
# ─────────────────────────────────────────────────────────────────────────────
async def fetch_or_free_models(client) -> tuple:
    or_key = get_provider_key("openrouter")
    if not or_key: return [], {}

    new_models = []; or_metadata = {}
    try:
        resp = await client.get(
            "https://openrouter.ai/api/v1/models",
            headers={"Authorization": f"Bearer {or_key}"}, timeout=20
        )
        if resp.status_code == 200:
            for m in resp.json().get("data", []):
                mid = m.get("id", "")
                if not mid: continue
                clean = strip_prefix(mid)
                ctx = m.get("context_length")
                pricing = m.get("pricing", {})
                or_metadata[mid] = {"ctx": int(ctx) if ctx else None, "pricing": pricing}
                or_metadata[clean] = or_metadata[mid]
                is_free = (float(pricing.get("prompt", 1)) == 0 and
                           float(pricing.get("completion", 1)) == 0)
                key = ("openrouter", clean)
                if key not in _seen_or and is_free:
                    _seen_or.add(key)
                    new_models.append({
                        "provider": "openrouter", "model": clean,
                        "base_url": "https://openrouter.ai/api/v1",
                        "key_env": "OPENROUTER_API_KEY", "original": mid,
                        "_ctx": int(ctx) if ctx else None, "_free": True
                    })
    except: pass
    return new_models, or_metadata

_seen_or = set()

# ─────────────────────────────────────────────────────────────────────────────
# MODELS.DEV INTEGRATION — context, pricing, capabilities
# ─────────────────────────────────────────────────────────────────────────────
_MODELS_DEV_CACHE = None

async def fetch_models_dev(client) -> dict:
    global _MODELS_DEV_CACHE
    if _MODELS_DEV_CACHE is not None: return _MODELS_DEV_CACHE

    # Try models_dev Python module
    try:
        from models_dev import providers
        data = {}
        for p in providers():
            for mid, m in p.models.items():
                data[mid] = {
                    "ctx": m.limit.context if hasattr(m, 'limit') else None,
                    "output": m.limit.output if hasattr(m, 'limit') else None,
                    "reasoning": getattr(m, 'reasoning', False),
                    "tool_call": getattr(m, 'tool_call', False),
                    "input_cost": m.cost.input if hasattr(m, 'cost') else None,
                    "output_cost": m.cost.output if hasattr(m, 'cost') else None,
                }
        _MODELS_DEV_CACHE = data; return data
    except ImportError: pass

    # Fallback: models.dev API
    try:
        resp = await client.get("https://models.dev/api/v0/models", timeout=30)
        if resp.status_code == 200:
            data = {}
            for p in resp.json():
                for m in p.get("models", []):
                    mid = m.get("id", "")
                    data[mid] = {
                        "ctx": m.get("context_length"),
                        "output": m.get("max_output_tokens"),
                        "reasoning": m.get("reasoning", False),
                        "tool_call": m.get("tool_call", False),
                        "input_cost": m.get("pricing", {}).get("prompt"),
                        "output_cost": m.get("pricing", {}).get("completion"),
                    }
            _MODELS_DEV_CACHE = data; return data
    except: pass

    _MODELS_DEV_CACHE = {}; return {}

