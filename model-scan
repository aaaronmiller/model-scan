# RENDER — TUIDS-LLM UNIFIED TABLE
# ─────────────────────────────────────────────────────────────────────────────
def render_table(results, duration, key_failures, healthy, degraded, failed, rerouted, total, providers_ok):
    TIER_ORDER = {"S": 0, "A": 1, "B": 2, "C": 3, "—": 4}
    def sort_key(r):
        return (TIER_ORDER.get(r.get("_tier", "—"), 5), -r.get("_composite", 0), -r.get("reliability", 0))
    results.sort(key=sort_key)

    try:
        import shutil; width = shutil.get_terminal_size().columns
    except: width = 120
    width = max(80, min(width, 160))

    # Header
    print()
    print(f"{C.INFO}󱙺 {C.INFO_D}FORGE{C.RST}  "
          f"{C.SECONDARY}{len(providers_ok)} providers{C.RST}  "
          f"{C.PRIMARY}{total} models{C.RST}  "
          f"{C.ERROR}{failed} failing{C.RST}  "
          f"{C.SUCCESS}{C.CHECK}{C.RST} AA: {C.SUCCESS_D}✓{C.RST}  "
          f"{C.META}│{C.RST}  {C.METRICS}⏱ {duration:.1f}s{C.RST}")

    # Column headers - comprehensive table
    sep = "─" * (width - 2)
    print(f"┌─{sep}┐")
    headers = (
        f"│ {C.INFO_D}TIER{C.RST} │ "
        f"{C.INFO_D}MODEL (provider){C.RST}".ljust(32) + " │ "
        f"{C.INFO_D}ROLE{C.RST}".ljust(10) + " │ "
        f"{C.INFO_D}AA{C.RST}".rjust(3) + " │ "
        f"{C.INFO_D}Cd{C.RST}".rjust(3) + " │ "
        f"{C.INFO_D}MLU{C.RST}".rjust(3) + " │ "
        f"{C.INFO_D}Rel{C.RST}".rjust(4) + " │ "
        f"{C.INFO_D}t/s{C.RST}".rjust(4) + " │ "
        f"{C.INFO_D}Lat{C.RST}".rjust(4) + " │ "
        f"{C.INFO_D}T{C.RST}".center(2) + " │ "
        f"{C.INFO_D}Ctx{C.RST}".rjust(5) + " │ "
        f"{C.INFO_D}STATUS{C.RST}".center(6) + " │"
    )
    print(headers)
    print(f"├─{sep}┤")

    # Rows
    for r in results:
        tier = r.get("_tier", "—")
        model = r.get("model", ""); prov = r.get("provider", "")
        role = r.get("_role", "—"); lat_s = r.get("lat_s", 0)
        tok_s = r.get("tok_s", 0); rel = r.get("reliability", 0)
        aa = get_aa(model)
        ai_score = aa.get("ai", 0)
        ac_score = aa.get("ac", 0)
        mmlu_score = aa.get("mmlu", 0)
        glyph, status_color, status_reason = get_status(r)
        has_tools = r.get("tools", False)

        # TIER coloring
        tier_color = (C.SUCCESS if tier == "S" else C.SUCCESS_D if tier == "A"
                      else C.SECONDARY if tier in ("B","C") else C.META)

        # AA Intelligence score
        if ai_score == 0: aa_str = f"{C.META}—{C.RST}".rjust(3)
        elif ai_score >= 80: aa_str = f"{C.METRICS}{ai_score}{C.RST}".rjust(3)
        elif ai_score >= 60: aa_str = f"{C.WARN}{ai_score}{C.RST}".rjust(3)
        else: aa_str = f"{C.ERROR_D}{ai_score}{C.RST}".rjust(3)

        # Coding score
        if ac_score == 0: cd_str = f"{C.META}—{C.RST}".rjust(3)
        elif ac_score >= 70: cd_str = f"{C.METRICS}{ac_score}{C.RST}".rjust(3)
        elif ac_score >= 50: cd_str = f"{C.WARN}{ac_score}{C.RST}".rjust(3)
        else: cd_str = f"{C.ERROR_D}{ac_score}{C.RST}".rjust(3)

        # MMLU score
        if mmlu_score == 0: mlu_str = f"{C.META}—{C.RST}".rjust(3)
        else: mlu_str = f"{C.METRICS}{mmlu_score*100:.0f}{C.RST}".rjust(3)

        # Reliability
        if rel >= 0.99: rel_str = f"{C.SUCCESS}{rel*100:.0f}%{C.RST}".rjust(4)
        elif rel >= 0.5: rel_str = f"{C.WARN}{rel*100:.0f}%{C.RST}".rjust(4)
        else: rel_str = f"{C.ERROR_D}0%{C.RST}".rjust(4)

        # T/S
        if tok_s == 0: ts_str = f"{C.META}—{C.RST}".rjust(4)
        elif tok_s < 1.0: ts_str = f"{C.WARN}{tok_s:.0f}{C.RST}".rjust(4)
        else: ts_str = f"{C.METRICS}{tok_s:.0f}{C.RST}".rjust(4)

        # LAT
        if lat_s == 0: lat_str = f"{C.META}—{C.RST}".rjust(4)
        elif lat_s > 5: lat_str = f"{C.ERROR}{lat_s:.0f}s{C.RST}".rjust(4)
        elif lat_s > 2: lat_str = f"{C.WARN}{lat_s:.0f}s{C.RST}".rjust(4)
        else: lat_str = f"{C.METRICS}{lat_s:.0f}s{C.RST}".rjust(4)

        # Tools
        tools_str = f"{C.SUCCESS}Y{C.RST}".center(2) if has_tools else f"{C.ERROR_D}n{C.RST}".center(2)

        # Context
        ctx = r.get("_ctx")
        if ctx: ctx_str = f"{C.METRICS}{ctx//1000}K{C.RST}".rjust(5)
        else: ctx_str = f"{C.META}—{C.RST}".rjust(5)

        # STATUS
        status_str = (f"{C.SUCCESS}{glyph}{C.RST}".center(6) if status_color == "success"
                      else f"{C.WARN}{glyph}{C.RST}".center(6) if status_color == "warn"
                      else f"{C.ERROR}{glyph}{C.RST}".center(6))

        # ROLE
        role_colors = {"primary": C.SUCCESS, "reasoner": C.INFO, "fast": C.METRICS,
                       "vision": C.INFO, "code": C.INFO, "hybrid": C.INFO,
                       "general": C.SECONDARY, "—": C.META}
        role_color = role_colors.get(role, C.SECONDARY)
        role_str = f"{role_color}{role}{C.RST}".ljust(10)

        # MODEL (sacred content — no ANSI on name)
        free_tag = f" {C.INFO_D}:free{C.RST}" if r.get("_free") else ""
        prov_str = f"{C.SECONDARY}({prov}){C.RST}"
        max_model = 22
        model_disp = model[:max_model-1] + "…" if len(model) > max_model else model
        model_str = f"{C.PRIMARY}{model_disp}{C.RST}" if tier == "S" else f"{C.SECONDARY}{model_disp}{C.RST}"

        row = (
            f"│ {tier_color}{tier}{C.RST} │ {model_str} {prov_str}{free_tag}".ljust(34) +
            f" │ {role_str} │ {aa_str} │ {cd_str} │ {mlu_str} │ {rel_str} │ {ts_str} │ {lat_str} │ {tools_str} │ {ctx_str} │ {status_str} │"
        )
        print(row)

    print(f"└─{sep}┘")

    # Footer
    print()
    footer = []
    if healthy: footer.append(f"{C.SUCCESS}{C.CHECK}{C.RST} {healthy} healthy")
    if degraded: footer.append(f"{C.WARN}{C.WARN_G}{C.RST} {degraded} degraded")
    if failed: footer.append(f"{C.ERROR}{C.CROSS}{C.RST} {failed} dead")
    if rerouted: footer.append(f"{C.ACCENT}{C.DIAMOND}{C.RST} {rerouted} rerouted")
    print("  ".join(footer))

    if key_failures:
        print()
        print(f"{C.META}│{C.RST}  {C.ERROR}󰓎 {len(key_failures)} keys failing{C.RST}")
        for kn, reason in key_failures.items():
            print(f"    {C.ERROR}{C.CROSS}{C.RST} {C.SECONDARY}{kn}{C.RST}  {reason}")

