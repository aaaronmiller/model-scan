        print(f"  {C.INFO}{C.ARROW}{C.INFO} Composite: {C.METRICS}{composite}{C.RST} → TIER: {C.SUCCESS}{tier}{C.RST}")

    print(f"{C.META}─── Live Metrics ───{C.RST}")
    print(f"  {C.SECONDARY}Latency:   {C.METRICS}{result.get('lat_s', 0):.1f}s{C.RST}")
    print(f"  {C.SECONDARY}Throughput:{C.METRICS}{result.get('tok_s', 0):.1f} tok/s{C.RST}")
    print(f"  {C.SECONDARY}Reliability:{C.METRICS}{result.get('reliability', 0)*100:.0f}%{C.RST}")
    print(f"  {C.SECONDARY}Role:      {C.INFO}{result.get('_role', '—')}{C.RST}")
    print(f"  {C.SUCCESS}  ✓ Tool-calling{C.RST}" if result.get('tools')
