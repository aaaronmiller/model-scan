# STATUS & FAILURE ANALYSIS
# ─────────────────────────────────────────────────────────────────────────────
FAIL_TYPES = {
    "auth_error": "401/403", "rate_limit": "429",
    "empty": "empty", "timeout": "T/O",
    "schema": "bad JSON", "http_4xx": "4xx",
    "http_5xx": "5xx", "unknown": "?",
}

def get_status(result: dict) -> tuple:
    rel = result.get("reliability", 0)
    lat_s = result.get("lat_s", 0)
    if rel >= 0.99: return (C.CHECK, "success", "")
    elif rel >= 0.5:
        reason = []
        if lat_s > 5: reason.append(f"{lat_s:.0f}s")
        dom = result.get("dom_fail", "")
        if dom: reason.append(FAIL_TYPES.get(dom, dom))
        return (C.WARN_G, "warn", " ".join(reason))
    else:
        dom = result.get("dom_fail", "")
        reason = FAIL_TYPES.get(dom, dom) if dom else "?"
        return (C.CROSS, "error", reason)

