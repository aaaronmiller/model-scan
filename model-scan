def _get_api_model(provider: str, model: str, original: str = None) -> str:
    """Get the model identifier to send to the API endpoint."""
    orig = original or model
    # For openrouter, ALWAYS use provider/model-id format
    if provider == "openrouter":
        return orig if orig else f"openrouter/{model}"
    # Groq uses bare model names (no slash)
    elif provider == "groq":
        return model.split("/")[-1] if "/" in model else model
    # Cerebras, OpenCode Go
    elif provider in ("cerebras", "opencode_go"):
        return model.split("/")[-1] if "/" in model else model
    return model

async def probe_model(client, provider: str, model: str, base_url: str,
                      key_env: str, shots: int = 1, original: str = None) -> dict:
    api_key = get_provider_key(provider)
    if not api_key:
        return {"provider": provider, "model": model, "reliability": 0,
                "lat_s": 0, "tok_s": 0, "empty": 0, "tools": False,
                "fails": {"auth_error": 1}, "dom_fail": "auth_error", "status": "no_key"}

    url = f"{base_url.rstrip('/')}/chat/completions"
    headers = {"Authorization": f"Bearer {api_key}", "Content-Type": "application/json"}
    api_model = _get_api_model(provider, model, original)

    payload = {
        "model": api_model,
        "messages": [{"role": "user", "content": "reply with one word: pong"}],
        "max_tokens": 256, "temperature": 0.0
    }

    ok = 0; empty = 0; lats = []; speeds = []; fails = []

    for _ in range(shots):
        t0 = time.perf_counter()
        try:
            resp = await client.post(url, json=payload, headers=headers, timeout=20)
            elapsed = time.perf_counter() - t0

            if resp.status_code in (401, 403): fails.append("auth_error"); continue
            if resp.status_code == 429: fails.append("rate_limit"); continue
            if resp.status_code >= 400: fails.append(f"http_{resp.status_code}"); continue

            try: data = resp.json()
            except: fails.append("schema"); continue

            choices = data.get("choices", [])
            if not choices: fails.append("empty"); empty += 1; continue

            content = (choices[0].get("message", {}).get("content", "") or "").strip()
            if not content: fails.append("empty"); empty += 1; continue

            ok += 1; lats.append(elapsed)
            usage = data.get("usage", {})
            ct = usage.get("completion_tokens") or max(1, len(content.split()))
            if elapsed > 0: speeds.append(ct / elapsed)

        except httpx.TimeoutException: fails.append("timeout")
        except Exception: fails.append("unknown")

    rel = ok / shots if shots else 0
    dom = Counter(fails).most_common(1)[0][0] if fails else None

    return {
        "provider": provider, "model": model,
        "reliability": rel,
        "lat_s": sum(lats)/len(lats) if lats else 0,
        "tok_s": sum(speeds)/len(speeds) if speeds else 0,
        "empty": empty, "tools": False,
        "fails": dict(Counter(fails)), "dom_fail": dom,
        "status": "ok" if rel >= 0.5 else "fail"
    }

async def probe_tools(client, provider: str, model: str, base_url: str, original: str = None) -> bool:
    api_key = get_provider_key(provider)
    if not api_key: return False
    url = f"{base_url.rstrip('/')}/chat/completions"
    headers = {"Authorization": f"Bearer {api_key}", "Content-Type": "application/json"}
    api_model = _get_api_model(provider, model, original)

    payload = {
        "model": api_model,
        "messages": [{"role": "user", "content": "What is 2+2?"}],
        "tools": [{"type": "function", "function": {
            "name": "calc", "description": "math",
            "parameters": {"type": "object", "properties": {"e": {"type": "string"}}, "required": ["e"]}
        }}],
        "max_tokens": 64, "temperature": 0.0
    }

    try:
        resp = await client.post(url, json=payload, headers=headers, timeout=15)
        if resp.status_code >= 400: return False
        data = resp.json()
        choices = data.get("choices", [])
        if not choices: return False
        msg = choices[0].get("message", {})
        return bool(msg.get("tool_calls") or
                    choices[0].get("finish_reason") in ("tool_calls", "function_call"))
    except: return False

