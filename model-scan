def check_key_health() -> dict:
    failures = {}
    if not get_provider_key("openrouter"): failures["OPENROUTER_API_KEY"] = "Not found"
    elif len(get_provider_key("openrouter")) < 10: failures["OPENROUTER_API_KEY"] = "Invalid"
    if not get_provider_key("nvidia"): failures["NVIDIA_API_KEY"] = "Not found"
    if not get_provider_key("groq"): failures["GROQ_API_KEY"] = "Not found"
    if not get_provider_key("cerebras"): failures["CEREBRAS_API_KEY"] = "Not found"
    return failures

# ─────────────────────────────────────────────────────────────────────────────
# HISTORY / PERSISTENCE
# ─────────────────────────────────────────────────────────────────────────────
CACHE_DIR = Path.home() / ".config" / "model-scan"
RESULTS_FILE = CACHE_DIR / "results.json"

def load_history() -> list:
    if not RESULTS_FILE.exists(): return []
    try:
        h = json.loads(RESULTS_FILE.read_text())
        return h[-30:] if isinstance(h, list) else [h]
    except: return []

def save_history(entry, history):
    history.append(entry); history = history[-30:]
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    RESULTS_FILE.write_text(json.dumps(history, indent=2))
    return history

def get_problematic(history, min_fail=3) -> dict:
    recent = history[-10:]; counts = {}
    for run in recent:
        for r in run.get("results", []):
            key = f"{r['provider']}/{r['model']}"
            if r.get("reliability", 1) < 0.5:
                counts[key] = counts.get(key, 0) + 1
    return {k: v for k, v in counts.items() if v >= min_fail}

# ─────────────────────────────────────────────────────────────────────────────
# SCAN LOOP — shared client for efficiency
# ─────────────────────────────────────────────────────────────────────────────
_md_data = None
_http_client = None

async def get_client():
    global _http_client
    if _http_client is None:
        _http_client = httpx.AsyncClient(timeout=20, limits=httpx.Limits(max_keepalive_connections=20))
    return _http_client

async def close_client():
    global _http_client
    if _http_client is not None:
        await _http_client.aclose()
        _http_client = None

async def scan_one(m, idx, total, md_data, args):
    """Scan a single model."""
    if not args.quiet:
        frame = (idx // 3) % len(SPINNERS)
        rid = f"{idx:04x}"
        print(f"\r{C.META}[{rid}]{C.RST} {C.INFO}{spin(frame)}{C.RST} "
              f"{m['provider']}/{m['model'][:30]}...  ", end="", flush=True)

    client = await get_client()
    r = await probe_model(client, m["provider"], m["model"], m["base_url"],
                          m["key_env"], shots=1, original=m.get("original", m["model"]))

    if r["reliability"] >= 0.5:
        r["tools"] = await probe_tools(client, m["provider"], m["model"],
                                       m["base_url"], original=m.get("original", m["model"]))
    else:
        r["tools"] = False

    # Attach metadata
    ctx = m.get("_ctx")
    if not ctx and md_data:
        md_entry = md_data.get(m["model"]) or md_data.get(m.get("original", ""))
        ctx = md_entry.get("ctx") if md_entry else None
    r["_ctx"] = ctx
    r["_free"] = m.get("_free", ":free" in m.get("original", ""))
    r["_md"] = (md_data.get(m["model"]) or md_data.get(m.get("original", ""))) if md_data else {}

    # Compute tier + role
    r["_tier"] = compute_tier(r)
    r["_composite"] = compute_composite(r)
    r["_role"] = assign_role(r)

    return r

# ─────────────────────────────────────────────────────────────────────────────
# MAIN SCAN
# ─────────────────────────────────────────────────────────────────────────────

async def run_scan(args):
    global _md_data
    _md_data = None
    t0 = time.perf_counter()

    history = load_history()
    problematic = get_problematic(history)
    key_failures = check_key_health()

    print(f"{C.INFO}󱙺 {C.INFO_D}FORGE{C.RST} {C.INFO}→{C.RST} {C.PRIMARY}model-scan v3{C.RST}")
    print(f"{C.META}Scanning providers...{C.RST}")

    model_list, providers_ok, providers_missing, bad_models = build_model_list(skip_bad=True)

    async with httpx.AsyncClient(timeout=30) as client:
        # Auto-fetch ALL OpenRouter free models (filter bad later via update_bad_models)
        new_models, or_metadata = await fetch_or_free_models(client)
        # Filter out already-known-bad models from OR fetch
        for m in new_models:
            key = f"openrouter/{m['model']}"
            if bad_models.get(key, 0) < 5:
                model_list.append(m)
        _md_data = await fetch_models_dev(client)

    if args.provider:
        model_list = [m for m in model_list if args.provider.lower() in m["provider"].lower()]

    if not model_list:
        print(f"{C.WARN}⚠ No models to scan. Check API keys.{C.RST}")
        return

    # Report missing keys
    if providers_missing:
        print(f"{C.WARN}⚠ Missing keys: {', '.join(providers_missing)}{C.RST}")

    total = len(model_list)
    print(f"{C.META}Probing {total} models concurrently...{C.RST}")

    # Concurrent scan with semaphore
    _sem = asyncio.Semaphore(8)
    
    async def scan_with_sem(m, i):
        async with _sem:
            return await scan_one(m, i, total, _md_data, args)
    
    # Use gather with return_exceptions to catch any errors
    tasks = [scan_with_sem(m, i) for i, m in enumerate(model_list)]
    
    # Force unbuffered output for progress
    import sys
    sys.stdout.flush()
    
    raw_results = await asyncio.gather(*tasks, return_exceptions=True)
    
    # Filter out exceptions
    results = []
    for i, r in enumerate(raw_results):
        if isinstance(r, Exception):
            print(f"\nError scanning model {i}: {r}", file=sys.stderr)
        elif isinstance(r, dict):
            results.append(r)
        else:
            print(f"\nUnexpected result type for model {i}: {type(r)}", file=sys.stderr)

    duration = time.perf_counter() - t0
    if not args.quiet: print()  # Clear progress line

    # Save history
    entry = {"scanned_at": datetime.now(timezone.utc).isoformat(), "results": results}
    history = save_history(entry, history)

    # Update bad models tracking
    bad_models = update_bad_models(results, bad_models)
    if bad_models:
        skipped = sum(1 for k,v in bad_models.items() if v >= 5)
        if skipped > 0:
            print(f"{C.WARN}⚠ Skipping {skipped} known-bad models (5+ failures){C.RST}")

    # Compute stats
    healthy = sum(1 for r in results if r.get("reliability", 0) >= 0.99)
    degraded = sum(1 for r in results if 0.5 <= r.get("reliability", 0) < 0.99)
    failed = sum(1 for r in results if r.get("reliability", 0) < 0.5)
    rerouted = 0

    if args.json:
        print(json.dumps(results, indent=2))
    elif not args.quiet:
        if args.working_only:
            results = [r for r in results if r.get("reliability", 0) >= 0.5]

        render_table(results, duration, key_failures, healthy, degraded,
                     failed, rerouted, total, providers_ok)

        if problematic:
            print(); print(f"{C.WARN}⚠ {len(problematic)} historically problematic{C.RST}")
            for m, c in sorted(problematic.items(), key=lambda x: -x[1])[:5]:
                print(f"  {C.ERROR}{C.CROSS}{C.RST} {m}: {c}x failures")

        if args.verbose and results:
            for r in results:
                if r.get("reliability", 0) < 0.5:
                    render_detail(r)

    await close_client()

# ─────────────────────────────────────────────────────────────────────────────
# MAIN
# ─────────────────────────────────────────────────────────────────────────────
def main():
    p = argparse.ArgumentParser(
        description="model-scan v3 — TUIDS-LLM model diagnostic panel",
        formatter_class=argparse.RawDescriptionHelpFormatter
    )
    p.add_argument("-w", "--working-only", action="store_true", help="Only show healthy models")
    p.add_argument("--json", action="store_true", help="Emit JSON")
    p.add_argument("-q", "--quiet", action="store_true", help="Suppress progress output")
    p.add_argument("-v", "--verbose", action="store_true", help="Show detail pane for failed models")
    p.add_argument("--provider", type=str, help="Filter by provider name")
    args = p.parse_args()
    asyncio.run(run_scan(args))

if __name__ == "__main__":
    main()
