def get_aa(model: str) -> dict:
    if model in AA: return AA[model]
    stripped = strip_prefix(model)
    if stripped in AA: return AA[stripped]
    or_prefixed = f"openrouter/{stripped}"
    if or_prefixed in AA: return AA[or_prefixed]
    return {}

# ─────────────────────────────────────────────────────────────────────────────
# UTILITIES
# ─────────────────────────────────────────────────────────────────────────────
def strip_prefix(model: str) -> str:
    if "/" not in model: return model
    p = model.split("/")[0].lower()
    known = {"openrouter","openai","anthropic","google","meta-llama","qwen","nvidia",
             "minimax","z-ai","cerebras","groq","poolside","inclusionai","tencent",
             "deepseek","moonshotai","arcee-ai","stepfun","elephant","opencode_go",
             "opencode-go","nvidia-nim","ollama"}
    return "/".join(model.split("/")[1:]) if p in known else model

def infer_moe(model: str) -> tuple:
    m = re.search(r'(\d+)x(\d+(?:\.\d+)?)b', model, re.I)
    if m:
        return (float(m.group(1)) * float(m.group(2)), float(m.group(2)))
    m = re.search(r'(?:^|[-/a-z])(\d+(?:\.\d+)?)b(?:[-/]|$)', model, re.I)
    if m: return (float(m.group(1)), float(m.group(1)))
    return (0.0, 0.0)

# ─────────────────────────────────────────────────────────────────────────────
# TIER GRADING — S/A/B/C based on composite score
# S: >89, A: 84-89 (MiniMax-2.7 baseline), B: 70-83, C: 55-69, —: ungraded
# ─────────────────────────────────────────────────────────────────────────────
MINIMAX_BASELINE = 84

def compute_tier(result: dict) -> str:
    aa = get_aa(result.get("model",""))
    ai_score = aa.get("ai", 0)
    lat_s = result.get("lat_s", 999)
    rel = result.get("reliability", 0)
    if rel < 0.5: return "—"

    composite = ai_score
    if lat_s > 5:   composite -= 10
    elif lat_s > 2: composite -= 5
    elif lat_s > 1: composite -= 2
    if rel >= 0.99: composite += 5

    total, activated = infer_moe(result.get("model",""))
    if activated and activated < total: composite += 3

    if composite >= MINIMAX_BASELINE + 5: return "S"
    elif composite >= MINIMAX_BASELINE: return "A"
    elif composite >= 70: return "B"
    elif composite >= 55: return "C"
    return "—"

def compute_composite(result: dict) -> int:
    aa = get_aa(result.get("model",""))
    composite = aa.get("ai", 0)
    lat_s = result.get("lat_s", 999)
    rel = result.get("reliability", 0)
    if lat_s > 5:   composite -= 10
    elif lat_s > 2: composite -= 5
    elif lat_s > 1: composite -= 2
    if rel >= 0.99: composite += 5
    return max(0, int(composite))

# ─────────────────────────────────────────────────────────────────────────────
# ROLE ASSIGNMENT — primary, reasoner, fast, vision, code, hybrid, general, —
# ─────────────────────────────────────────────────────────────────────────────
def assign_role(result: dict) -> str:
    rel = result.get("reliability", 0)
    tok_s = result.get("tok_s", 0)
    aa = get_aa(result.get("model",""))
    ai = aa.get("ai", 0)
    has_tools = result.get("tools", False)
    if rel < 0.5: return "—"

    tier = compute_tier(result)
    if tier == "S" and has_tools and ai >= 85: return "primary"
    if ai >= 70 and not has_tools and tok_s < 50: return "reasoner"
    if tok_s >= 100 and rel >= 0.9: return "fast"
    model = result.get("model", "").lower()
    if any(x in model for x in ["vision", "gemini", "claude"]): return "vision"
    if aa.get("ac", 0) >= 65: return "code"
    if has_tools and ai >= 60: return "hybrid"
    if has_tools: return "general"
    return "—"

