# ─────────────────────────────────────────────────────────────────────────────
# BAD MODELS TRACKING — skip repeatedly failing models
# ─────────────────────────────────────────────────────────────────────────────
BAD_MODELS_FILE = Path.home() / ".config" / "model-scan" / "bad_models.json"

def load_bad_models() -> dict:
    """Load bad models: {provider/model: fail_count}"""
    if not BAD_MODELS_FILE.exists():
        return {}
    try:
        return json.loads(BAD_MODELS_FILE.read_text())
    except:
        return {}

def save_bad_models(bad: dict):
    """Save bad models, incrementing fail counts"""
    BAD_MODELS_FILE.parent.mkdir(parents=True, exist_ok=True)
    BAD_MODELS_FILE.write_text(json.dumps(bad, indent=2))

def update_bad_models(results: list, bad: dict, threshold: int = 5):
    """Update bad models based on scan results"""
    changed = False
    for r in results:
        key = f"{r['provider']}/{r['model']}"
        rel = r.get("reliability", 0)
        dom_fail = r.get("dom_fail", "")
        
        # Skip quota/rate-limit - those recover
        if dom_fail in ("rate_limit", "429"):
            continue
        
        if rel < 0.5:
            bad[key] = bad.get(key, 0) + 1
            changed = True
        elif rel >= 1.0:
            # Model recovered - reduce count
            if key in bad:
                bad[key] = max(0, bad[key] - 1)
                if bad[key] == 0:
                    del bad[key]
                changed = True
    
    if changed:
        save_bad_models(bad)
    
    return bad

# ─────────────────────────────────────────────────────────────────────────────
# MODEL LIST BUILDER
# ─────────────────────────────────────────────────────────────────────────────
def build_model_list(skip_bad: bool = True) -> tuple:
    models = []; seen = set(); providers_ok = []; providers_missing = []
    bad = load_bad_models() if skip_bad else {}
    
    for prov_id, cfg in PROVIDERS.items():
        if not has_provider_key(prov_id):
            providers_missing.append(prov_id); continue
        providers_ok.append(prov_id)

        for m in cfg.get("models", []):
            bare = strip_prefix(m)
            key = (prov_id, bare)
            if key in seen: continue
            
            # Skip bad models
            if skip_bad and bad.get(key, 0) >= 5:
                seen.add(key)
                continue
                
            seen.add(key)
            models.append({
                "provider": prov_id, "model": bare,
                "base_url": cfg["base_url"], "key_env": cfg["key_env"],
                "original": m
            })

    return models, providers_ok, providers_missing, bad

